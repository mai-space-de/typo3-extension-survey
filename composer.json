{
    "name": "maispace/mai-survey",
    "type": "typo3-cms-extension",
    "description": "Survey and Mitmach-Matrix extension for TYPO3",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Maispace",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "maispace/mai-base": "@dev",
        "typo3/cms-core": "^14.1",
        "typo3/cms-extbase": "^14.1",
        "typo3/cms-fluid": "^14.1"
    },
    "suggest": {
        "maispace/mai-account": "For authenticated submission restriction",
        "maispace/mai-mail": "For admin notification emails"
    },
    "autoload": {
        "psr-4": {
            "Maispace\\MaiSurvey\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maispace\\MaiSurvey\\Tests\\": "Tests"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "mai_survey"
        },
        "branch-alias": {
            "dev-main": "14.0.x-dev"
        }
    },
    "scripts": {
        "lint:check": [
            "@check:editorconfig",
            "@check:phpcs",
            "@check:phpstan",
            "@check:typoscript"
        ],
        "lint:fix": [
            "@fix:editorconfig",
            "@fix:phpcs"
        ],
        "check:editorconfig": "ec",
        "fix:editorconfig": "ec --fix",
        "check:phpcs": "php-cs-fixer check --diff",
        "fix:phpcs": "php-cs-fixer fix",
        "check:phpstan": "phpstan analyse",
        "check:phpstan:baseline": "phpstan analyse --generate-baseline",
        "check:typoscript": "typoscript-lint",
        "test": "@test:unit",
        "test:unit": "phpunit -c phpunit.xml.dist"
    }
}
