{
    "name": "maispace/mai-survey",
    "type": "typo3-cms-extension",
    "description": "Survey and Mitmach-Matrix extension for TYPO3",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Maispace",
            "role": "Developer"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../*",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.2",
        "maispace/mai-base": "@dev",
        "typo3/cms-core": "^14.1",
        "typo3/cms-extbase": "^14.1",
        "typo3/cms-fluid": "^14.1"
    },
    "require-dev": {
        "armin/editorconfig-cli": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.0",
        "helmich/typo3-typoscript-lint": "^3.1",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "saschaegerer/phpstan-typo3": "^3.0",
        "typo3/testing-framework": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Maispace\\MaiSurvey\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maispace\\MaiSurvey\\Tests\\": "Tests"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "mai_survey"
        },
        "branch-alias": {
            "dev-main": "14.0.x-dev"
        }
    },
    "scripts": {
        "lint:check": [
            "@check:editorconfig",
            "@check:phpcs",
            "@check:phpstan",
            "@check:typoscript",
            "@composer validate --strict --no-check-version --no-check-all --no-check-publish"
        ],
        "lint:fix": [
            "@fix:editorconfig",
            "@fix:phpcs",
            "@check:phpstan",
            "@check:typoscript"
        ],
        "check:editorconfig": "ec -unv -e vendor/ -e public/ -e var/",
        "fix:editorconfig": "ec -unvf -e vendor/ -e public/ -e var/",
        "check:phpcs": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer check --config .php-cs-fixer.php --ansi --verbose --diff",
        "fix:phpcs": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix --config .php-cs-fixer.php --ansi",
        "check:phpstan": "phpstan analyse --no-progress",
        "check:phpstan:baseline": "phpstan analyse --no-progress --generate-baseline=phpstan-baseline.neon",
        "check:typoscript": "typoscript-lint --fail-on-warnings -c typoscript-lint.yml Configuration/",
        "test": "phpunit --configuration phpunit.xml.dist",
        "test:unit": "phpunit --configuration phpunit.xml.dist --testsuite Unit"
    },
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        },
        "platform": {
            "php": "8.5.0"
        },
        "platform-check": false,
        "sort-packages": true
    }
}
